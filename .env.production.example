# GramSathi AI — Production Environment Variables
# Copy this file to .env.production and fill with production values
# WARNING: Do not commit secrets to version control!

# ─── Database ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://gramsathi:${DB_PASSWORD}@${DB_HOST}:5432/gramsathi
DB_PASSWORD=
DB_HOST=
DB_POOL_SIZE=50
DB_MAX_OVERFLOW=100
DB_ECHO=false

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:6379
REDIS_PASSWORD=
REDIS_HOST=
REDIS_DB=0

# ─── Auth / JWT ────────────────────────────────────────
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
OTP_EXPIRY_SECONDS=300
OTP_LENGTH=6
OTP_PROVIDER=msg91

# ─── Google Cloud ──────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=/etc/secrets/gcp-service-account.json
GOOGLE_CLOUD_PROJECT=gramsathi-prod
GCS_DOCUMENTS_BUCKET=gramsathi-documents-prod
GCS_EXPIRATION_MINUTES=30

# ─── AI / Gemini ──────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
GEMINI_FLASH_MODEL=gemini-1.5-flash
GEMINI_MAX_TOKENS=8192
GEMINI_TEMPERATURE=0.3

# ─── Speech (STT/TTS) ─────────────────────────────────
SPEECH_LANGUAGE_CODE=hi-IN
SPEECH_ENCODING=LINEAR16
SPEECH_SAMPLE_RATE=16000

# ─── Firebase (Push Notifications) ─────────────────────
FIREBASE_PROJECT_ID=gramsathi-prod
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=

# ─── Twilio (SMS / WhatsApp) ─────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# ─── BigQuery (Analytics) ────────────────────────────
BIGQUERY_DATASET=gramsathi_analytics
BIGQUERY_LOCATION=asia-south1

# ─── Application Settings ───────────────────────────
APP_NAME=GramSathi
APP_ENV=production
APP_DEBUG=false
APP_LOG_LEVEL=WARNING
APP_CORS_ORIGINS=https://admin.gramsathi.ai,https://gramsathi.ai
API_RATE_LIMIT_PER_MINUTE=120
API_VERSION=v1

# ─── Feature Flags ────────────────────────────────────
FEATURE_AI_CHAT_ENABLED=true
FEATURE_VOICE_IVR_ENABLED=true
FEATURE_OCR_AUTOFILL_ENABLED=true
FEATURE_BULK_APPROVE_ENABLED=true

# ─── Monitoring ──────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.gramsathi.ai:4318
OTEL_SERVICE_NAME=gramsathi

# ─── External APIs ──────────────────────────────────
MSG91_AUTH_KEY=
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
