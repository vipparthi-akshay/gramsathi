# GramSathi AI — Development Environment Variables
# Copy this file to .env and adjust for local development

# ─── Database ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://gramsathi:gramsathi-dev@localhost:5432/gramsathi
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_ECHO=false

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Auth / JWT ────────────────────────────────────────
JWT_SECRET_KEY=change-this-in-production-please
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
OTP_EXPIRY_SECONDS=300
OTP_LENGTH=6
OTP_PROVIDER=mock  # Options: mock, twilio, msg91, amazon_sns

# ─── Google Cloud ──────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json
GOOGLE_CLOUD_PROJECT=gramsathi-dev
GCS_DOCUMENTS_BUCKET=gramsathi-documents-dev
GCS_EXPIRATION_MINUTES=60

# ─── AI / Gemini ──────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro
GEMINI_FLASH_MODEL=gemini-1.5-flash
GEMINI_MAX_TOKENS=8192
GEMINI_TEMPERATURE=0.7

# ─── Speech (STT/TTS) ─────────────────────────────────
SPEECH_LANGUAGE_CODE=hi-IN
SPEECH_ENCODING=LINEAR16
SPEECH_SAMPLE_RATE=16000

# ─── Firebase (Push Notifications) ─────────────────────
FIREBASE_PROJECT_ID=gramsathi-dev
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=

# ─── Twilio (SMS / WhatsApp) ─────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# ─── BigQuery (Analytics) ────────────────────────────
BIGQUERY_DATASET=gramsathi_analytics
BIGQUERY_LOCATION=asia-south1

# ─── Application Settings ───────────────────────────
APP_NAME=GramSathi
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=DEBUG
APP_CORS_ORIGINS=*
API_RATE_LIMIT_PER_MINUTE=60
API_VERSION=v1

# ─── Feature Flags ────────────────────────────────────
FEATURE_AI_CHAT_ENABLED=true
FEATURE_VOICE_IVR_ENABLED=true
FEATURE_OCR_AUTOFILL_ENABLED=true
FEATURE_BULK_APPROVE_ENABLED=true

# ─── Monitoring ──────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=gramsathi

# ─── External APIs ──────────────────────────────────
MSG91_AUTH_KEY=
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
